# =============================================================================
# .gitignore for ISAC 6G MATLAB Project
# =============================================================================

# MATLAB workspace files (auto-generated, can be regenerated by running scripts)
*.mat
workspace_S*.mat

# MATLAB autosave / temporary files
*.asv
*.m~
*.mex*
*.autosave

# MATLAB compiled files
*.p

# MATLAB code generation
codegen/
slprj/

# MATLAB simulink
*.slxc

# MATLAB published HTML output
html/

# =============================================================================
# Operating System Files
# =============================================================================

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# =============================================================================
# IDE / Editor Files
# =============================================================================

# VS Code
.vscode/
*.code-workspace

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml

# =============================================================================
# Python (in case you add Python implementations later)
# =============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv
*.egg-info/
.ipynb_checkpoints/

# =============================================================================
# Logs and Output
# =============================================================================

*.log
*.out
*.err
results/temp/

# =============================================================================
# Backup and Archive Files
# =============================================================================

*.bak
*.backup
*.old
*.tmp
*.zip
*.tar.gz

# =============================================================================
# DO NOT IGNORE these (commented out for reference)
# =============================================================================
# !docs/*.docx       # Keep documentation
# !docs/*.pptx       # Keep presentations
# !docs/*.png        # Keep flowcharts
# !references/*.pdf  # Keep reference papers
